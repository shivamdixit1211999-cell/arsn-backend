# Copy this to .env.local — never commit .env.local to git

# ── Shopify Storefront API ────────────────────────────────────────────────────
# Step 1: Get these from Shopify Admin → Apps → Develop apps → Storefront API
VITE_SHOPIFY_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_TOKEN=your-storefront-access-token

# Step 2: Flip to "true" when ready to go live on real products
# While "false" the app uses the local 28-SKU mock catalog
VITE_USE_SHOPIFY=false

# ── Razorpay ─────────────────────────────────────────────────────────────────
# Set once you receive key from Razorpay dashboard
VITE_RAZORPAY_KEY_ID=
